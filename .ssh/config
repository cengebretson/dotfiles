# Added by OrbStack: 'orb' SSH host for Linux machines
# This only works if it's at the top of ssh_config (before any Host blocks).
# This won't be added again if you remove it.
Include ~/.orbstack/ssh/config

# Load keys from the macOS keychain and add to the agent on first use,
# so no per-session `ssh-add` (or passphrase prompt) is needed once the
# passphrase has been cached once via `ssh-add --apple-use-keychain ~/.ssh/chris`.
Host *
AddKeysToAgent yes
UseKeychain yes

# Machine-local host entries (personal servers, LAN devices) — not tracked.
# Placed inside the matching `Host *` scope so the included blocks actually
# apply (an Include inside a non-matching Host block is parsed but ignored).
# See ~/.ssh/config.local; create it per-machine.
Include ~/.ssh/config.local

# github (allows tunneling)

Host github.com
User git
Hostname ssh.github.com
Port 443
IdentityFile ~/.ssh/chris

