// Zed settings
//
// For information on how to configure Zed, see the Zed
// documentation: https://zed.dev/docs/configuring-zed
//
// To see all of Zed's default settings without changing your
// custom settings, run the `open default settings` command
// from the command palette or from `Zed` application menu.
{
  "which_key": {
    "enabled": true
  },
  "agent_ui_font_size": 18.0,
  "agent_buffer_font_size": 16.0,
  "buffer_line_height": {
    "custom": 1.7000000476837158,
  },
  "session": {
    "trust_all_worktrees": true,
  },
  "agent_servers": {
    "claude-acp": {
      "type": "registry",
    },
  },
  "icon_theme": {
    "mode": "light",
    "light": "Catppuccin Mocha",
    "dark": "Catppuccin Mocha"
  },
  "theme": {
    "mode": "system",
    "light": "One Light",
    "dark": "Catppuccin Frappé"
  },
  "agent": {
    "inline_assistant_model": {
      "provider": "copilot_chat",
      "model": "gpt-5-mini",
    },
    "default_profile": "write",
    "default_model": {
      "provider": "openrouter",
      "model": "qwen/qwen3-coder",
    },
  },
  "use_system_window_tabs": true,
  "rounded_selection": true,
  "lsp_document_colors": "inlay",
  "inline_code_actions": false,
  "minimap": {
    "show": "never",
  },
  "title_bar": {
    "show_user_picture": false,
  },
  "search": {
    "button": false,
    "case_sensitive": true,
  },
  "project_panel": {
    "starts_open": true,
    "sticky_scroll": true,
    "dock": "left",
  },
  "terminal": {
    "font_family": "JetBrains Mono NL",
    "keep_selection_on_copy": false,
    "toolbar": {
      "breadcrumbs": false,
    },
  },
  "toolbar": {
    "breadcrumbs": true,
    "quick_actions": false,
    "selections_menu": false,
  },
  "ui_font_family": "JetBrains Mono NL",
  "buffer_font_family": "JetBrains Mono NL",
  "buffer_font_weight": 150.0,
  "feature_flags": {
    "edit_prediction_provider": "zed",
  },
  "cursor_blink": true,
  "cursor_shape": "bar",
  "bottom_dock_layout": "contained",
  "hide_mouse": "on_typing",
  // Will be triggered manually with `ctrl-x ctrl-c`.
  "show_edit_predictions": false,
  "inlay_hints": {
    "enabled": false,
  },
  "telemetry": {
    "metrics": false,
    "diagnostics": false,
  },
  "vim_mode": true,
  "ui_font_size": 17.0,
  "buffer_font_size": 14.0,
  "relative_line_numbers": "enabled",
  "tab_bar": {
    "show": true,
  },
  "scrollbar": {
    "show": "auto",
  },
  // Rainbow indentation
  "indent_guides": {
    "enabled": true,
    "coloring": "indent_aware",
  },
  "tabs": {
    "show_diagnostics": "all",
    "file_icons": true,
    "git_status": true,
  },
  "preview_tabs": {
    "enabled": false,
  },
  "git": {
    "git_gutter": "tracked_files",
    "inline_blame": {
      "enabled": true,
    },
  },
  "status_bar": {
    "active_language_button": true,
    "cursor_position_button": true,
    "experimental.show": true,
  },
  "vim": {
    "gdefault": true,
    "use_smartcase_find": true,
    "toggle_relative_line_numbers": true,
    "use_system_clipboard": "always",
    "use_autoclose": false,
    "cursor_shape": {
      "normal": "hollow",
      "insert": "bar",
      "visual": "block",
    },
  },
  "languages": {},
  "wrap_guides": [90],
  "show_wrap_guides": false,
}
