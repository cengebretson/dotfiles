# Per-machine account/auth state — never share across machines
auth.json
.credentials.json

# Runtime and session data
sessions/
history.jsonl
log/
logs/
tmp/
.tmp/
cache/
context-mode/
plugins/cache/
plugins/.marketplace-plugin-source-staging/
shell_snapshots/
version.json
*.log
*.sqlite
*.sqlite-shm
*.sqlite-wal
*.db
*.db-shm
*.db-wal

# Machine-local Codex state
config.toml
installation_id
.personality_migration
models_cache.json
hooks.json.bak.*
goals_*
logs_*
memories_*
state_*
.codex-global-state.json*
session_index.jsonl
docker-local.config.toml

# Per-machine caches and import history
claude-cowork-import-history.json
claude-cowork-transcript-imports/
cloud-config-bundle-cache.json
cloud-requirements-cache.json
vendor_imports/

# Installed macOS computer-use app bundle (binary, not config)
computer-use/

# Memories live in their own nested git repo, not in dotfiles
memories/

# Live execpolicy rules auto-grow per machine/repo (auto_review learns them) —
# keep machine-local; share curated rules via a *.dotfiles-reference-* snapshot instead.
rules/default.rules
# Local rules backups / reference snapshots
rules/*.backup-*
rules/*.dotfiles-reference-*

# Installed/vendored skills are managed by Codex, not personal dotfiles
skills/.system/
skills/playwright/

# Note: AGENTS.md and config.shared.toml are intentionally trackable.
# Keep secrets out of shared config — use env vars, never hardcoded keys.
