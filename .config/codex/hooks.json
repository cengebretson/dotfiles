{
  "hooks": {
    "PermissionRequest": [
      {
        "matcher": ".*",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/codex/hooks/dispatch.sh\" permission-request-notify"
          },
          {
            "type": "command",
            "command": "\"$HOME/.config/codex/hooks/dispatch.sh\" moshi"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/codex/hooks/dispatch.sh\" local-instructions"
          },
          {
            "type": "command",
            "command": "\"$HOME/.config/codex/hooks/dispatch.sh\" moshi"
          },
          {
            "type": "command",
            "command": "\"$HOME/.config/codex/hooks/dispatch.sh\" domain-docs"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/codex/hooks/dispatch.sh\" moshi"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/codex/hooks/dispatch.sh\" prompt-clear"
          },
          {
            "type": "command",
            "command": "\"$HOME/.config/codex/hooks/dispatch.sh\" moshi"
          }
        ]
      }
    ]
  }
}
