# font settings
font-size = 16
#font-family = "Iosevka Light"
font-family="JetBrains Mono ExtraLight"
adjust-cell-height = 17
bold-is-bright = true

# theme
theme = Catppuccin Mocha
background-opacity = .90
background-blur-radius = 25

# cursor
cursor-style = block

# mouse settings
mouse-hide-while-typing = true
mouse-scroll-multiplier = 2

# window settings
window-padding-balance = true
window-padding-x = 5
window-padding-y = 5
window-save-state = always
window-colorspace = "display-p3"
window-padding-color = extend
window-inherit-working-directory = true
#window-decoration = false
resize-overlay = after-first

# keybindings
keybind = cmd+s>r=reload_config
keybind = cmd+s>x=close_surface
keybind = cmd+s>n=new_window
keybind = cmd+s>f=toggle_fullscreen
keybind = cmd+k=clear_screen

# allow tmux to use these keybindings
keybind = ctrl+tab=unbind
keybind = ctrl+shift+tab=unbind
keybind = alt+shift+tab=unbind

# quick terminal
keybind = global:cmd+grave_accent=toggle_quick_terminal

# other/misc
shell-integration = fish
copy-on-select = clipboard
shell-integration-features = no-cursor,sudo,no-title
clipboard-trim-trailing-spaces = true
clipboard-paste-protection = true
scrollback-limit = 0

# macos settings
macos-titlebar-style = transparent
macos-titlebar-proxy-icon = hidden
macos-icon = custom
macos-option-as-alt = true

# shaders
#custom-shader = /Users/chris/.config/ghostty/shaders/cursor_smear.glsl
#custom-shader = /Users/chris/.config/ghostty/shaders/cursor_blaze.glsl
custom-shader = /Users/chris/.config/ghostty/shaders/cursor_blaze_no_trail.glsl
#custom-shader = /Users/chris/.config/ghostty/shaders/cursor_smear_fade.glsl
#custom-shader = /Users/chris/.config/ghostty/shaders/cursor_frozen.glsl
#custom-shader = /Users/chris/.config/ghostty/shaders/just-snow.glsl
#custom-shader = /Users/chris/.config/ghostty/shaders/inside-the-matrix.glsl

# only set this during testing, defaults to "true" which animates only active windows
custom-shader-animation = always

# updates
auto-update = check
auto-update-channel = stable

