      "Bash(docker compose *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git rebase*)",
      "Bash(git worktree *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push)",
      "Bash(git push origin*)",
      "Bash(pre-commit *)",
      "mcp__atlassian__*",
      "mcp__claude_ai_Atlassian__*",
      "mcp__plugin_context-mode_context-mode__*",
      "Bash(mkdir -p *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(docker exec *)",
      "Bash(ssh-add -l)",
      "Bash(eza *)",
      "Bash(cd * && npx eslint*)",
      "Bash(cd * && npx prettier*)",
      "Bash(cd * && npx vitest*)",
      "Bash(cd * && npm run*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(git clean -nd*)",
      "Bash(git ls-files*)",
      "Bash(sleep *)",
      "Bash(echo *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(ast-grep *)",
      "Bash(shellcheck *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(go *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(bat *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(sed -n *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(luac -p *)",
      "Bash(glow *)",
      "Bash(scc *)",
      "Bash(delta *)",
      "Bash(difft *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(comm *)",
      "Bash(nvim --headless *)",
      "Bash(grep *)",
      "Bash(test *)",
      "Bash(open *)",
      "Bash(git for-each-ref*)",
      "Bash(git rev-list*)",
      "Bash(git merge-base*)",
      "Bash(git merge-tree*)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(uv *)",
      "Bash(python3 *)",
      "Bash(prettier *)",
      "Bash(stylua *)",
      "Bash(mise *)",
      "Bash(gh api*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr create*)",
      "Bash(gh pr ready*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr comment*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "mcp__github__*",
      "Bash(git restore*)",
      "Bash(git reset*)",
      "Bash(PATH=* pre-commit *)",
      "Bash(PATH=* git commit*)",
      "Bash(pr-report*)"
    ],
    "deny": [
      "Bash(git clean -f*)",
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Bash(docker compose * down -v*)"
    ]
  },
  "model": "opus",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/format-on-edit.sh\""
          }
        ]
      }
    ],
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.config/tmux/plugins/tmux-attention/scripts/tmux-attention input # tmux-attention:claude:notification"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.config/tmux/plugins/tmux-attention/scripts/tmux-attention blocked # tmux-attention:claude:stop-failure"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME\"/.config/tmux/plugins/tmux-attention/scripts/tmux-attention clear # tmux-attention:claude:user-prompt-submit"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/context-mode-cache-heal.mjs\" >/dev/null 2>&1"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/claude/statusline.sh",
    "hideVimModeIndicator": true
  },
  "enabledPlugins": {
    "context-mode@context-mode": true,
    "github@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "effortLevel": "high",
  "theme": "dark-ansi",
  "editorMode": "vim"
}
