{
  "permissions": {
    "allow": [
      "mcp__plugin_context-mode_context-mode__*",
      "Bash(mkdir -p *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(docker exec *)",
      "Bash(ssh-add -l)",
      "Bash(echo *)",
      "Bash(ast-grep *)",
      "Bash(yq *)",
      "Bash(go *)",
      "Bash(nvim --headless *)",
      "Bash(open *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(uv *)",
      "Bash(python3 *)",
      "Bash(prettier *)",
      "Bash(stylua *)",
      "Bash(mise *)",
      "Bash(gh api*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr create*)",
      "Bash(gh pr ready*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr comment*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "mcp__github__*",
      "Bash(pr-report*)",
      "Bash(git add*)",
      "Bash(git restore*)",
      "Bash(git stash*)",
      "Bash(git commit*)",
      "Bash(git push*)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git merge*)",
      "Bash(git rebase*)",
      "Bash(git cherry-pick*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git branch*)",
      "Bash(git tag*)",
      "Bash(git reset*)",
      "Bash(git ls-remote*)",
      "Bash(git remote*)",
      "Bash(git release*)"
    ],
    "deny": [
      "Bash(git clean -f*)",
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Bash(docker compose * down -v*)"
    ],
    "additionalDirectories": []
  },
  "model": "opus",
  "hooks": {
    "Notification": [
      {
        "matcher": "permission_prompt|idle_prompt",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" notification"
          }
        ]
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" moshi",
            "async": false
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" format-on-edit"
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" moshi",
            "async": true
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" moshi",
            "async": true
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/approve-compound-bash.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "AskUserQuestion",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" moshi",
            "async": true
          }
        ]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" moshi",
            "async": true
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" moshi",
            "async": true
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" context-mode-cache-heal >/dev/null 2>&1"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" moshi",
            "async": true
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" moshi",
            "async": true
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" stop-failure"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" prompt-clear"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"$HOME/.config/claude/hooks/dispatch.sh\" moshi",
            "async": true
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/claude/statusline.sh",
    "hideVimModeIndicator": true
  },
  "enabledPlugins": {
    "context-mode@context-mode": true,
    "github@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true,
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "/private/tmp"
      ]
    }
  },
  "effortLevel": "high",
  "theme": "dark-ansi",
  "editorMode": "vim",
  "tui": "fullscreen"
}
