{
  "permissions": {
    "allow": [
      "Bash(make *)",
      "Bash(docker compose *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git rebase*)",
      "Bash(git worktree *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push)",
      "Bash(git push origin*)",
      "Bash(npm run lint*)",
      "Bash(npm run test:unit *)",
      "Bash(npx eslint*)",
      "Bash(npx prettier*)",
      "Bash(pre-commit *)",
      "mcp__claude_ai_Atlassian__*",
      "mcp__github__*",
      "mcp__plugin_context-mode_context-mode__*",
      "Bash(mkdir -p *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(docker exec *)",
      "Bash(npm run build*)",
      "Bash(npm run dev*)",
      "Bash(npm install *)",
      "Bash(npm ci)",
      "Bash(ssh-add -l)",
      "Bash(npx vitest run *)",
      "Bash(eza *)",
      "Bash(cd * && npx eslint*)",
      "Bash(cd * && npx prettier*)",
      "Bash(cd * && npx vitest*)",
      "Bash(cd * && npm run*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(git clean -nd*)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(ast-grep *)",
      "Bash(npx tsc*)",
      "Bash(npx vue-tsc*)",
      "Bash(shellcheck *)",
      "Bash(jq *)",
      "Bash(yq *)"
    ],
    "deny": [
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Bash(docker compose * down -v*)"
    ]
  },
  "model": "claude-fable-5[1m]",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"/Users/cengebretson/.claude/hooks/context-mode-cache-heal.mjs\""
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/claude/statusline.sh",
    "hideVimModeIndicator": true
  },
  "enabledPlugins": {
    "context-mode@context-mode": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "source": "github",
        "repo": "mksglu/context-mode"
      }
    }
  },
  "effortLevel": "high",
  "theme": "dark-ansi",
  "editorMode": "vim"
}
