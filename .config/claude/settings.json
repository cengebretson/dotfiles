{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chris/.config/claude/hooks/claude-code-preview.sh"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Edit|Write|NotebookEdit",
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chris/.config/claude/hooks/claude-code-preview.sh"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/Users/chris/.config/claude/hooks/claude-code-preview.sh"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.config/claude/statusline.sh",
    "hideVimModeIndicator": true
  },
  "effortLevel": "medium",
  "theme": "dark-ansi",
  "editorMode": "vim"
}
