{
  "editorMode": "vim",
  "effortLevel": "high",
  "enabledPlugins": {
    "context-mode@context-mode": true,
    "github@claude-plugins-official": true
  },
  "extraKnownMarketplaces": {
    "context-mode": {
      "source": {
        "repo": "mksglu/context-mode",
        "source": "github"
      }
    }
  },
  "hooks": {
    "Notification": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.config/tmux/plugins/tmux-attention/scripts/tmux-attention input # tmux-attention:claude:notification",
            "type": "command"
          }
        ],
        "matcher": "permission_prompt|idle_prompt"
      }
    ],
    "PermissionRequest": [
      {
        "hooks": [
          {
            "async": false,
            "command": "'/opt/homebrew/bin/moshi-hook' claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "hooks": [
          {
            "command": "\"$HOME/.config/claude/hooks/format-on-edit.sh\"",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write|MultiEdit"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "'/opt/homebrew/bin/moshi-hook' claude-hook",
            "type": "command"
          }
        ],
        "matcher": "AskUserQuestion"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "'/opt/homebrew/bin/moshi-hook' claude-hook",
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "PreToolUse": [
      {
        "hooks": [
          {
            "async": true,
            "command": "'/opt/homebrew/bin/moshi-hook' claude-hook",
            "type": "command"
          }
        ],
        "matcher": "AskUserQuestion"
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "'/opt/homebrew/bin/moshi-hook' claude-hook",
            "type": "command"
          }
        ],
        "matcher": "ExitPlanMode"
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "async": true,
            "command": "'/opt/homebrew/bin/moshi-hook' claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "command": "\"$HOME/.config/claude/hooks/context-mode-cache-heal.mjs\" \u003e/dev/null 2\u003e\u00261",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "'/opt/homebrew/bin/moshi-hook' claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "async": true,
            "command": "'/opt/homebrew/bin/moshi-hook' claude-hook",
            "type": "command"
          }
        ]
      }
    ],
    "StopFailure": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.config/tmux/plugins/tmux-attention/scripts/tmux-attention blocked # tmux-attention:claude:stop-failure",
            "type": "command"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "command": "\"$HOME\"/.config/tmux/plugins/tmux-attention/scripts/tmux-attention clear # tmux-attention:claude:user-prompt-submit",
            "type": "command"
          }
        ]
      },
      {
        "hooks": [
          {
            "async": true,
            "command": "'/opt/homebrew/bin/moshi-hook' claude-hook",
            "type": "command"
          }
        ]
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "additionalDirectories": [
      "/Users/cengebretson/workspace/worktrees"
    ],
    "allow": [
      "Bash(make *)",
      "Bash(~/projects/los/misc/setup-worktree.sh*)",
      "Bash(/Users/cengebretson/workspace/scripts/setup-worktree.sh*)",
      "Bash(fish -n *)",
      "Bash(docker compose *)",
      "Bash(git fetch*)",
      "Bash(git pull*)",
      "Bash(git checkout*)",
      "Bash(git switch*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git rebase*)",
      "Bash(git worktree *)",
      "Bash(git push --force-with-lease*)",
      "Bash(git push)",
      "Bash(git push origin*)",
      "Bash(pre-commit *)",
      "mcp__atlassian__*",
      "mcp__claude_ai_Atlassian__*",
      "mcp__plugin_context-mode_context-mode__*",
      "Bash(mkdir -p *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(git stash *)",
      "Bash(git merge *)",
      "Bash(docker exec *)",
      "Bash(ssh-add -l)",
      "Bash(eza *)",
      "Bash(cd * \u0026\u0026 npx eslint*)",
      "Bash(cd * \u0026\u0026 npx prettier*)",
      "Bash(cd * \u0026\u0026 npx vitest*)",
      "Bash(cd * \u0026\u0026 npm run*)",
      "Bash(git log*)",
      "Bash(git status*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(git remote*)",
      "Bash(git rev-parse*)",
      "Bash(git clean -nd*)",
      "Bash(git ls-files*)",
      "Bash(sleep *)",
      "Bash(echo *)",
      "Bash(rg *)",
      "Bash(fd *)",
      "Bash(ast-grep *)",
      "Bash(shellcheck *)",
      "Bash(jq *)",
      "Bash(yq *)",
      "Bash(go *)",
      "Bash(git mv *)",
      "Bash(git rm *)",
      "Bash(bat *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(sed -n *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(luac -p *)",
      "Bash(glow *)",
      "Bash(scc *)",
      "Bash(delta *)",
      "Bash(difft *)",
      "Bash(wc *)",
      "Bash(sort *)",
      "Bash(comm *)",
      "Bash(nvim --headless *)",
      "Bash(grep *)",
      "Bash(test *)",
      "Bash(open *)",
      "Bash(git for-each-ref*)",
      "Bash(git rev-list*)",
      "Bash(git merge-base*)",
      "Bash(git merge-tree*)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(bun *)",
      "Bash(bunx *)",
      "Bash(uv *)",
      "Bash(python3 *)",
      "Bash(prettier *)",
      "Bash(stylua *)",
      "Bash(mise *)",
      "Bash(gh api*)",
      "Bash(gh pr view*)",
      "Bash(gh pr list*)",
      "Bash(gh pr diff*)",
      "Bash(gh pr checks*)",
      "Bash(gh pr create*)",
      "Bash(gh pr ready*)",
      "Bash(gh pr edit*)",
      "Bash(gh pr comment*)",
      "Bash(gh run view*)",
      "Bash(gh run list*)",
      "mcp__github__*",
      "Bash(git restore*)",
      "Bash(git reset*)",
      "Bash(PATH=* pre-commit *)",
      "Bash(PATH=* git commit*)",
      "Bash(pr-report*)"
    ],
    "deny": [
      "Bash(git clean -f*)",
      "Bash(git push --force *)",
      "Bash(git push --force)",
      "Bash(git push -f*)",
      "Bash(git reset --hard*)",
      "Bash(rm -rf *)",
      "Bash(docker compose * down -v*)"
    ]
  },
  "sandbox": {
    "autoAllowBashIfSandboxed": true,
    "enabled": true,
    "filesystem": {
      "allowWrite": [
        "/tmp",
        "/private/tmp"
      ]
    }
  },
  "statusLine": {
    "command": "~/.config/claude/statusline.sh",
    "hideVimModeIndicator": true,
    "type": "command"
  },
  "theme": "dark-ansi"
}
