#!/usr/bin/env bash
#
# git-release — cut a release for the current git repository.
#
#   git release <version|major|minor|patch> [--dry-run]
#   git release --current
#
# Bumps the VERSION file, promotes the CHANGELOG "[Unreleased]" section to the
# new version, runs the repo's tests, commits, and creates an annotated tag.
# Pushing is left to you so you can review the commit and tag first.
#
# Repo-agnostic:
#   * the project web URL is derived from the "origin" remote
#   * the test runner is auto-detected: tests/check.sh, else `make test`
#     (override with GIT_RELEASE_TEST_CMD)
set -euo pipefail

die() { echo "git-release: $*" >&2; exit 1; }

# The current version: the VERSION file if present, else the latest git tag
# (without its leading "v"), else 0.0.0 for a repo that has never released.
read_current_version() {
    if [[ -f VERSION ]]; then
        cat VERSION
    else
        local t
        t="$(git describe --tags --abbrev=0 2>/dev/null || true)"
        if [[ -n "${t}" ]]; then echo "${t#v}"; else echo "0.0.0"; fi
    fi
}

# Apply a major/minor/patch bump to an X.Y.Z version (e.g. minor: 0.5.0 -> 0.6.0).
bump_version() {
    local kind="$1" cur="$2" ma mi pa
    [[ "${cur}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] \
        || die "current version '${cur}' is not X.Y.Z; pass an explicit version instead"
    IFS=. read -r ma mi pa <<< "${cur}"
    case "${kind}" in
        major) ma=$((ma + 1)); mi=0; pa=0 ;;
        minor) mi=$((mi + 1)); pa=0 ;;
        patch) pa=$((pa + 1)) ;;
    esac
    echo "${ma}.${mi}.${pa}"
}

# Succeeds if the CHANGELOG's [Unreleased] section has real entries (a non-blank
# line that is not a "### Group" subheading) before the next version heading.
unreleased_has_content() {
    awk '
        /^## \[Unreleased\]/ { inblock = 1; next }
        inblock && (/^## \[/ || /^\[Unreleased\]:/) { inblock = 0 }
        inblock && NF && !/^###/ { found = 1 }
        END { exit found ? 0 : 1 }
    ' CHANGELOG.md
}

usage() {
    cat <<'EOF'
git-release — cut a release for the current git repository.

Usage:
  git release <version|major|minor|patch> [options]
  git release --current        print the current version and exit

A bump keyword is applied to the current version (minor: 0.5.0 -> 0.6.0);
or pass an explicit X.Y.Z.

Options:
  -n, --dry-run             preview the release without changing anything
  -p, --push                push the branch and tag when done
  --allow-empty-changelog   release even if [Unreleased] has no entries
  -c, --current             print the current version and exit
  -h, --help                show this help

Bumps VERSION, promotes the CHANGELOG [Unreleased] section, runs the repo's
tests, commits, and creates an annotated tag vX.Y.Z. Without --push, publish
manually with:

  git push origin <branch> --follow-tags

The current version comes from the VERSION file, or the latest git tag if there
is none. The test runner is auto-detected (tests/check.sh, else `make test`;
override with GIT_RELEASE_TEST_CMD). The project URL is derived from origin.
EOF
}

spec=""
dry_run=false
show_current=false
push=false
allow_empty_changelog=false
for arg in "$@"; do
    case "${arg}" in
        -n|--dry-run) dry_run=true ;;
        -c|--current) show_current=true ;;
        -p|--push) push=true ;;
        --allow-empty-changelog) allow_empty_changelog=true ;;
        -h|--help) usage; exit 0 ;;
        -*) die "unknown option: ${arg}" ;;
        *) [[ -z "${spec}" ]] || die "unexpected argument: ${arg}"; spec="${arg}" ;;
    esac
done

# Operate from the repo root regardless of where we were invoked.
root="$(git rev-parse --show-toplevel 2>/dev/null)" || die "not inside a git repository"
cd "${root}"

current="$(read_current_version)"

if [[ "${show_current}" == true ]]; then
    echo "${current}"
    exit 0
fi

# Resolve the target version: a bump keyword applied to the current version, or
# an explicit X.Y.Z.
case "${spec}" in
    major|minor|patch) version="$(bump_version "${spec}" "${current}")" ;;
    "") usage >&2; exit 1 ;;
    *)
        [[ "${spec}" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] \
            || die "not a version or bump keyword: ${spec} (use X.Y.Z, or major|minor|patch)"
        version="${spec}"
        ;;
esac
tag="v${version}"

# Derive the project web URL from the origin remote.
remote="$(git remote get-url origin 2>/dev/null)" || die "no 'origin' remote configured"
remote="${remote%.git}"
case "${remote}" in
    git@*:*)
        hostpath="${remote#git@}"
        web="https://${hostpath%%:*}/${hostpath#*:}"
        ;;
    ssh://*)
        rest="${remote#ssh://}"; rest="${rest#*@}"
        web="https://${rest}"
        ;;
    *)
        web="${remote}"
        ;;
esac

# Preconditions. Under --dry-run these are notes (so you can preview a pending
# release) rather than hard failures.
precheck() {
    if [[ "${dry_run}" == true ]]; then
        echo "git-release: note: $* (would block a real release)" >&2
    else
        die "$*"
    fi
}
[[ -z "$(git status --porcelain)" ]] || precheck "working tree is not clean; commit or stash first"
if git rev-parse -q --verify "refs/tags/${tag}" >/dev/null 2>&1; then
    precheck "tag ${tag} already exists"
fi

prev_tag="$(git describe --tags --abbrev=0 2>/dev/null || true)"
date_str="$(date +%Y-%m-%d)"

if [[ -f VERSION ]]; then old_version="$(cat VERSION)"; else old_version="(none)"; fi

# Detect the test runner.
if [[ -n "${GIT_RELEASE_TEST_CMD:-}" ]]; then
    test_cmd="${GIT_RELEASE_TEST_CMD}"
elif [[ -x tests/check.sh ]]; then
    test_cmd="tests/check.sh"
elif [[ -f Makefile ]] && grep -qE '^test:' Makefile; then
    test_cmd="make test"
else
    test_cmd=""
fi

# Decide what to do with the CHANGELOG.
#   promote — file exists with an [Unreleased] section -> add a dated heading
#   create  — no file -> scaffold a Keep a Changelog skeleton for this version
#   none    — file exists but has no [Unreleased] section -> leave it alone
if [[ -f CHANGELOG.md ]] && grep -qE '^## \[Unreleased\]' CHANGELOG.md; then
    changelog_action="promote"
    changelog_note="promote [Unreleased] -> [${version}] - ${date_str}"
elif [[ -f CHANGELOG.md ]]; then
    changelog_action="none"
    changelog_note="CHANGELOG.md has no [Unreleased] section — leaving it untouched"
else
    changelog_action="create"
    changelog_note="create CHANGELOG.md with a [${version}] - ${date_str} section"
fi

# Guard against publishing a release with empty notes.
if [[ "${changelog_action}" == "promote" ]] && ! unreleased_has_content; then
    if [[ "${allow_empty_changelog}" == true ]]; then
        changelog_note="${changelog_note} (WARNING: [Unreleased] is empty)"
    elif [[ "${dry_run}" == true ]]; then
        changelog_note="${changelog_note} (EMPTY — would block; pass --allow-empty-changelog)"
    else
        die "[Unreleased] in CHANGELOG.md has no entries; add notes or pass --allow-empty-changelog"
    fi
fi

if [[ "${push}" == true ]]; then push_note="and push to origin"; else push_note="(no push)"; fi

if [[ "${dry_run}" == true ]]; then
    cat <<EOF
[dry-run] repo:         ${web}
[dry-run] new version:  ${version}  (tag ${tag})
[dry-run] previous tag: ${prev_tag:-(none)}
[dry-run] test runner:  ${test_cmd:-(none detected)}
[dry-run] VERSION:      ${old_version} -> ${version}
[dry-run] CHANGELOG:    ${changelog_note}
[dry-run] would run tests, commit VERSION/CHANGELOG, tag ${tag} ${push_note}
EOF
    exit 0
fi

# Bump the version file.
printf "%s\n" "${version}" > VERSION

# Apply the changelog change.
if [[ "${changelog_action}" == "promote" ]]; then
    awk -v ver="${version}" -v d="${date_str}" -v tag="${tag}" -v prev="${prev_tag}" -v web="${web}" '
        /^## \[Unreleased\]/ && !promoted {
            print
            print ""
            print "## [" ver "] - " d
            promoted = 1
            next
        }
        /^\[Unreleased\]:/ {
            print "[Unreleased]: " web "/compare/" tag "...HEAD"
            if (prev != "")
                print "[" ver "]: " web "/compare/" prev "..." tag
            else
                print "[" ver "]: " web "/releases/tag/" tag
            next
        }
        { print }
    ' CHANGELOG.md > CHANGELOG.md.tmp
    mv CHANGELOG.md.tmp CHANGELOG.md
elif [[ "${changelog_action}" == "create" ]]; then
    {
        cat <<EOF
# Changelog

All notable changes to this project are documented in this file.

The format is based on [Keep a Changelog](https://keepachangelog.com/en/1.1.0/),
and this project adheres to [Semantic Versioning](https://semver.org/spec/v2.0.0.html).

## [Unreleased]

## [${version}] - ${date_str}

EOF
        printf '[Unreleased]: %s/compare/%s...HEAD\n' "${web}" "${tag}"
        if [[ -n "${prev_tag}" ]]; then
            printf '[%s]: %s/compare/%s...%s\n' "${version}" "${web}" "${prev_tag}" "${tag}"
        else
            printf '[%s]: %s/releases/tag/%s\n' "${version}" "${web}" "${tag}"
        fi
    } > CHANGELOG.md
fi

# Run the repo's tests before tagging.
if [[ -n "${test_cmd}" ]]; then
    echo "Running tests: ${test_cmd}"
    bash -c "${test_cmd}"
else
    echo "git-release: no test runner detected; skipping tests" >&2
fi

git add -- VERSION
if [[ -f CHANGELOG.md ]]; then git add -- CHANGELOG.md; fi
git commit -m "Release ${tag}"
git tag -a "${tag}" -m "${tag}"

branch="$(git symbolic-ref --short HEAD 2>/dev/null || echo main)"
echo "Tagged ${tag}."

if [[ "${push}" == true ]]; then
    echo "Pushing ${branch} and ${tag} to origin..."
    git push origin "${branch}" --follow-tags
    echo "Pushed ${tag}; the release workflow will publish it."
else
    cat <<EOF

Review the commit and changelog, then publish with:

  git push origin ${branch} --follow-tags

EOF
fi
