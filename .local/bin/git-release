#!/usr/bin/env bash
set -euo pipefail

lib_dir="${GIT_RELEASE_LIB_DIR:-$HOME/.local/lib/git-release}"

for module in common version changelog workflow; do
	path="$lib_dir/$module.sh"
	if [[ ! -r "$path" ]]; then
		printf 'git-release: missing module: %s\n' "$path" >&2
		exit 1
	fi
	# shellcheck source=/dev/null
	source "$path"
done

git_release_main "$@"
