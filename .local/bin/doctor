#!/usr/bin/env bash
set -u

script_name="$(basename "$0")"
lib_dir="${DOCTOR_LIB_DIR:-$HOME/.local/lib/doctor}"

usage() {
	cat <<'EOF'
Usage:
  doctor ai
  doctor dotfiles
  doctor docker

Subcommands are read-only:
  ai       Audit Claude Code + Codex readiness.
  dotfiles Audit dotfile tracking, protections, and syntax.
  docker   Inspect Docker/OrbStack readiness and disk usage.

For destructive Docker cleanup, use docker-maint.
EOF
}

load_module() {
	local module="$1"
	if [[ ! -r "$lib_dir/common.sh" || ! -r "$lib_dir/$module.sh" ]]; then
		printf '%s: missing module under %s\n' "$script_name" "$lib_dir" >&2
		exit 1
	fi
	# shellcheck source=/dev/null
	source "$lib_dir/common.sh"
	# shellcheck source=/dev/null
	source "$lib_dir/$module.sh"
}

[[ $# -gt 0 ]] || {
	usage
	exit 2
}

case "$1" in
ai | --ai)
	[[ $# -eq 1 ]] || {
		printf '%s: ai does not take options\n' "$script_name" >&2
		exit 2
	}
	load_module ai
	run_ai_doctor
	;;
dotfiles | --dotfiles)
	[[ $# -eq 1 ]] || {
		printf '%s: dotfiles does not take options\n' "$script_name" >&2
		exit 2
	}
	load_module dotfiles
	run_dotfiles_doctor
	;;
docker | --docker)
	[[ $# -eq 1 || "${2:-}" = status ]] || {
		printf '%s: docker is read-only; use docker-maint for cleanup\n' "$script_name" >&2
		exit 2
	}
	load_module docker
	run_docker_doctor
	;;
-h | --help | help) usage ;;
*)
	printf '%s: unknown target: %s\n' "$script_name" "$1" >&2
	usage >&2
	exit 2
	;;
esac
