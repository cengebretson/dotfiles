#!/usr/bin/env bash
# ai-doctor — one health/audit report for the AI coding agents (Claude Code + Codex CLI).
#
# Read-only. This owns all "doctoring": hook-plumbing checks (moved out of each dispatch.sh,
# which now only dispatches), dependency presence, integration/plugin state, and skills parity.
# To see what's MISSING and how to install it, diff the Integrations sections below against the
# registry in ~/.config/AI-SETUP.md. Exit non-zero if any hard check fails (warns don't fail).
set -u

CLAUDE_DIR="$HOME/.config/claude"
CODEX_DIR="$HOME/.config/codex"
TMUX_ATTENTION="$HOME/.config/tmux/plugins/tmux-attention/scripts/tmux-attention"

fails=0
warns=0

# Colors/symbols only when writing to a terminal (clean when piped/redirected).
if [ -t 1 ]; then
  R=$'\033[0m'; DIM=$'\033[2m'; BOLD=$'\033[1m'
  GREEN=$'\033[32m'; YELLOW=$'\033[33m'; RED=$'\033[31m'; HEAD=$'\033[1;36m'
else
  R='' DIM='' BOLD='' GREEN='' YELLOW='' RED='' HEAD=''
fi

line() { # status label [detail]
  local status="$1" label="$2" detail="${3:-}" sym col
  case "$status" in
    ok) sym='✓' col=$GREEN ;;
    warn) sym='⚠' col=$YELLOW; warns=$((warns + 1)) ;;
    fail) sym='✗' col=$RED; fails=$((fails + 1)) ;;
    *) sym='·' col= ;;
  esac
  if [ -n "$detail" ]; then
    printf '  %s%s%s %-23s %s%s%s\n' "$col" "$sym" "$R" "$label" "$DIM" "$detail" "$R"
  else
    printf '  %s%s%s %s\n' "$col" "$sym" "$R" "$label"
  fi
}

section() { printf '\n%s▸ %s%s\n' "$HEAD" "$1" "$R"; }

have() { command -v "$1" >/dev/null 2>&1; }

moshi_present() { have moshi-hook || [ -x /opt/homebrew/bin/moshi-hook ]; }

check_routes() { # config_file
  local f="$1"
  if [ -f "$f" ] && grep -q 'dispatch.sh' "$f"; then
    line ok config "$(basename "$f")"
  else
    line warn config "$(basename "$f") — no dispatch.sh route"
  fi
}

list_skills() { # dir -> one skill name per line
  local d="$1" p
  [ -d "$d" ] || return 0
  for p in "$d"/*/; do [ -d "$p" ] && basename "$p"; done
}
skill_has() { list_skills "$1" | grep -qx "$2"; }

printf '%sai-doctor%s  %sClaude Code + Codex readiness%s\n' "$BOLD" "$R" "$DIM" "$R"

# --- Dependencies (from Brewfile) ---
section "Dependencies"
for t in bash shfmt jq node npx fish gh rg fd bat eza delta codex; do
  if have "$t"; then line ok "$t"; else line warn "$t" "missing — brew bundle --file ~/.config/Brewfile"; fi
done

# --- Claude hook plumbing ---
section "Claude hooks"
if [ -x "$CLAUDE_DIR/hooks/dispatch.sh" ]; then line ok dispatcher; else line fail dispatcher "not executable"; fi
if [ -x "$TMUX_ATTENTION" ]; then line ok tmux-attention; else line warn tmux-attention missing; fi
if moshi_present; then line ok moshi-hook; else line warn moshi-hook missing; fi
if [ -x "$CLAUDE_DIR/hooks/format-on-edit.sh" ]; then line ok format-on-edit; else line warn format-on-edit missing; fi
if [ -f "$CLAUDE_DIR/hooks/context-mode-cache-heal.mjs" ]; then line ok context-mode-cache-heal; else line warn context-mode-cache-heal missing; fi
if [ -x "$CLAUDE_DIR/hooks/approve-compound-bash.sh" ]; then line ok approve-compound-bash; else line warn approve-compound-bash missing; fi
if have shfmt; then line ok shfmt "approve-compound-bash dep"; else line warn shfmt "missing — approve-compound-bash falls through"; fi
if [ -x /opt/homebrew/bin/bash ] || [ -x /usr/local/bin/bash ]; then line ok modern-bash "approve-compound-bash dep"; else line warn modern-bash "missing — needs bash 4.3+ via Homebrew; macOS ships 3.2"; fi
check_routes "$CLAUDE_DIR/settings.json"

# --- Codex hook plumbing ---
section "Codex hooks"
if [ -x "$CODEX_DIR/hooks/dispatch.sh" ]; then line ok dispatcher; else line fail dispatcher "not executable"; fi
if [ -x "$TMUX_ATTENTION" ]; then line ok tmux-attention; else line warn tmux-attention missing; fi
if moshi_present; then line ok moshi-hook; else line warn moshi-hook missing; fi
check_routes "$CODEX_DIR/hooks.json"

# --- Integrations (state; diff against the AI-SETUP.md registry for missing/how-to) ---
section "Integrations — Claude plugins"
if have jq; then
  while IFS= read -r p; do [ -n "$p" ] && line ok "$p"; done \
    < <(jq -r '.enabledPlugins // {} | to_entries[] | select(.value) | .key' "$CLAUDE_DIR/settings.json" 2>/dev/null)
else
  line warn jq "missing — cannot read enabledPlugins"
fi

section "Integrations — Codex MCP + plugins"
if have codex; then
  while IFS= read -r row; do
    [ -n "$row" ] || continue
    if printf '%s' "$row" | grep -q 'Not logged in'; then
      line warn "${row%% *}" "mcp · not logged in"
    else
      line ok "${row%% *}" "mcp"
    fi
  done < <(codex mcp list 2>/dev/null | awk 'NF && $1 != "Name" {print}')
  while IFS= read -r row; do
    [ -n "$row" ] && line ok "${row%% *}" "plugin · installed"
  done < <(codex plugin list 2>/dev/null | grep 'installed' | grep -v 'not installed')
  avail="$(codex plugin list 2>/dev/null | grep -c 'not installed')"
  line ok "(catalog)" "${avail:-0} more available — codex plugin list"
else
  line warn codex "CLI missing"
fi

# --- Skills parity ---
section "Skills parity (Claude vs Codex)"
before=$warns
while IFS= read -r s; do
  [ -n "$s" ] && { skill_has "$CODEX_DIR/skills" "$s" || line warn skills "Claude-only: $s"; }
done < <(list_skills "$CLAUDE_DIR/skills")
while IFS= read -r s; do
  [ -n "$s" ] && { skill_has "$CLAUDE_DIR/skills" "$s" || line warn skills "Codex-only: $s"; }
done < <(list_skills "$CODEX_DIR/skills")
[ "$warns" -eq "$before" ] && line ok skills "in sync"

# --- Summary ---
section "Summary"
if [ "$fails" -gt 0 ]; then
  printf '  %s✗ %d fail%s · %s⚠ %d warn%s\n' "$RED" "$fails" "$R" "$YELLOW" "$warns" "$R"
elif [ "$warns" -gt 0 ]; then
  printf '  %s⚠ %d warn%s · 0 fail\n' "$YELLOW" "$warns" "$R"
else
  printf '  %s✓ all good%s\n' "$GREEN" "$R"
fi
printf '  %sNext: diff Integrations vs the registry in ~/.config/AI-SETUP.md to install any missing.%s\n' "$DIM" "$R"
[ "$fails" -gt 0 ] && exit 1
exit 0
